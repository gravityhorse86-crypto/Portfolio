// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// 1. ユーザー情報
model User {
  id                 String      @id @default(uuid())
  username           String
  email              String
  encrypted_password String
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt
}

// 2. 暗唱文
model Sentence {
  id          String            @id @default(uuid())
  content     String         // 暗唱文 (NOT NULL)
  translation String         // 日本語訳 (NOT NULL)
  
  // LLMで生成した文章
  casualText  String?        // カジュアル
  formalText  String?        // フォーマル

  created_at  DateTime       @default(now())
  updated_at  DateTime       @updatedAt
  
  status_id   String            // 習得状況のID
  status      SentenceStatus @relation(fields: [status_id], references: [id]) // 習得状況テーブルと紐づけ
}

// 3. 習得状況
model SentenceStatus {
  id        String        @id @default(uuid())
  name      String     // 習得状況（覚えてない、怪しい、覚えた）
  sentences Sentence[] // 紐づく暗唱文のリスト
}